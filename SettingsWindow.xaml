<Window x:Class="AkkDictionaryApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Save" Width="80" Click="SaveButton_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>

        <ScrollViewer DockPanel.Dock="Top">
            <StackPanel Margin="10">
                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <CheckBox x:Name="EnableSuggestionsCheckBox" Content="Enable Suggestions" Margin="0,0,0,12"/>

                <CheckBox x:Name="DefaultReverseSearchCheckBox" Content="Default to Reverse Search (Myanmar → English)" Margin="0,0,0,12"/>

                <CheckBox x:Name="RememberWindowCheckBox" Content="Remember Window Size and Position" Margin="0,0,0,20"/>

                <TextBlock Text="UI Font Family:" Margin="0,0,0,4"/>
                <TextBox x:Name="UIFontFamilyTextBox" Margin="0,0,0,12" Padding="4"/>

                <TextBlock Text="Font Scale (1.0 = normal):" Margin="0,0,0,4"/>
                <TextBox x:Name="FontScaleTextBox" Margin="0,0,0,12" Padding="4"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>