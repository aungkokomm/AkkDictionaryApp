<Window x:Class="AkkDictionaryApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="320" Width="480" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F5F5F5" FontFamily="Segoe UI"
        SizeToContent="WidthAndHeight">
    <Grid Margin="40,30,40,30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="AKK En-to-MM Dictionary" FontSize="26" FontWeight="Bold" 
                       Foreground="#333" TextAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <TextBlock Text="A comprehensive English-Myanmar dictionary" FontSize="14" 
                       Foreground="#666" TextAlignment="Center" Margin="0,0,0,25" TextWrapping="Wrap"/>

            <TextBlock Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,25" TextAlignment="Center" FontSize="13">
                <Run Text="Built with .NET 8 + WPF + SQLite"/>
            </TextBlock>

            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" FontSize="13" Margin="0,0,0,30">
                <Run Text="GitHub: " Foreground="#333"/>
                <Hyperlink NavigateUri="https://github.com/aungkokomm/English-Myanmar-Dictionary-" 
                           Click="Hyperlink_Click" Foreground="#0066CC">
                    <Run Text="View on GitHub"/>
                </Hyperlink>
            </TextBlock>

            <Button Content="Close" Width="120" Height="38" Margin="0,10,0,0" 
                    HorizontalAlignment="Center" Click="Close_Click" 
                    Background="#0066CC" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
